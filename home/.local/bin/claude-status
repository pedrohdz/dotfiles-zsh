#! /usr/bin/env bash

set -o pipefail
set -o errexit
set -o nounset

# ---------------------------------------------------------------------------
# Claude Code status line script.
# Reads the JSON context object from stdin; prints a single status line.
# ---------------------------------------------------------------------------

_input=$(cat)

_bold=$'\033[1m'
_dim=$'\033[2m'
_reset=$'\033[0m'
_cyan=$'\033[36m'
_yellow=$'\033[33m'
_green=$'\033[32m'
_red=$'\033[31m'
_magenta=$'\033[35m'
_sep="${_dim} │ ${_reset}"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
effort_colored() {
  case "${1:-}" in
    low)   printf '%s%s%s' "$_green"              "low"   "$_reset" ;;
    medium) printf '%s%s%s' "$_yellow"            "med"   "$_reset" ;;
    high)  printf '%s%s%s' "$_red"                "high"  "$_reset" ;;
    xhigh) printf '%s%s%s' "${_bold}${_red}"      "xhigh" "$_reset" ;;
    max)   printf '%s%s%s' "${_bold}${_magenta}"  "MAX"   "$_reset" ;;
    *)     printf '%s' "${1:-}" ;;
  esac
}

context_bar() {
  local _pct="${1:-0}" _width=8
  local _filled=$(( (_pct * _width + 50) / 100 ))
  local _bar="" _i

  for (( _i = 0; _i < _width; _i++ )); do
    if (( _i < _filled )); then _bar+="█"; else _bar+="░"; fi
  done

  local _color="$_green"
  (( _pct >= 50 )) && _color="$_yellow"
  (( _pct >= 80 )) && _color="$_red"

  printf '%s%s%s %d%%' "$_color" "$_bar" "$_reset" "$_pct"
}


# ---------------------------------------------------------------------------
# Extract data from JSON
# ---------------------------------------------------------------------------
_model=$(   jq -r '.model.display_name    // ""' <<< "$_input")
_cwd=$(     jq -r '.workspace.current_dir // ""' <<< "$_input")
_used_pct=$(jq -r '.context_window.used_percentage // ""' <<< "$_input")
_effort=$(  jq -r '.effort.level          // ""' <<< "$_input")

# Account name from CLAUDE_CONFIG_DIR (set by claude-account wrapper)
_account=""
[[ -n "${CLAUDE_CONFIG_DIR:-}" ]] && _account="${CLAUDE_CONFIG_DIR##*/}"

# Git branch (fast: reads .git/HEAD directly)
_branch=""
[[ -n "$_cwd" ]] && _branch=$(git -C "$_cwd" branch --show-current 2>/dev/null || true)

# Collapse $HOME to ~
_display_cwd="${_cwd/#$HOME/\~}"


# ---------------------------------------------------------------------------
# Assemble parts
# ---------------------------------------------------------------------------
_parts=()

[[ -n "$_account"  ]] && _parts+=("${_bold}${_cyan}[${_account}]${_reset}")
[[ -n "$_model"    ]] && _parts+=("${_dim}${_model}${_reset}")
[[ -n "$_effort"   ]] && _parts+=("$(effort_colored "$_effort")")

_loc="$_display_cwd"
[[ -n "$_branch"   ]] && _loc+=" ${_yellow}(${_branch})${_reset}"
[[ -n "$_loc"      ]] && _parts+=("$_loc")

[[ -n "$_used_pct" ]] && _parts+=("$(context_bar "$_used_pct")")

# Join with separator
_out=""
for _part in "${_parts[@]}"; do
  [[ -n "$_out" ]] && _out+="$_sep"
  _out+="$_part"
done

printf '%s' "$_out"
