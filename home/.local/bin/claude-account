#! /usr/bin/env bash

set -o pipefail
set -o errexit
set -o nounset

_CLAUDE_BIN="${CLAUDE_BIN:-/Users/pfh/.local/bin/claude}"
_ACCOUNTS_DIR="${CLAUDE_ACCOUNTS_DIR:-${HOME}/.claude-accounts}"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
fatal() {
  echo "FATAL - $*" >&2
  exit 1
}

print_status() {
  local _account_dir="$_ACCOUNTS_DIR/$_ACCOUNT"
  if [[ -t 2 ]]; then
    printf '\033[1m%s\033[0m: \033[36m%s\033[0m → \033[36m%s\033[0m\n' \
      "${0##*/}" "$_ACCOUNT" "$_account_dir" >&2
  else
    printf '%s: %s → %s\n' "${0##*/}" "$_ACCOUNT" "$_account_dir" >&2
  fi
}

usage() {
  cat <<EOF
Usage: ${0##*/} <account> [CLAUDE_ARGS...]
       ${0##*/} --init <account>
       ${0##*/} --list

Run Claude Code under a named account with an isolated config directory.

Commands:
  <account> [CLAUDE_ARGS...]   Run claude with the given account's config
  --init,  -i <account>        Create account directory and run initial auth
  --setup, -s <account>        Apply/refresh default settings on an existing account
  --list,  -l                  List configured accounts
  --help,  -h                  Show this help and exit

Symlink usage (preferred):
  ln -s claude-account ~/.local/bin/claude-outnordic
  claude-outnordic [CLAUDE_ARGS...]   # account derived from invoked name

Environment:
  CLAUDE_BIN           Path to the claude binary.
                       Default: $_CLAUDE_BIN
  CLAUDE_ACCOUNTS_DIR  Directory containing per-account config directories.
                       Default: $_ACCOUNTS_DIR
EOF
}


# ---------------------------------------------------------------------------
# Argument parsing and configuration
# ---------------------------------------------------------------------------
_COMMAND=""
_ACCOUNT=""
_CLAUDE_ARGS=()

configure() {
  # Symlink mode: invoked as claude-<account> (e.g. claude-outnordic)
  local _self="${0##*/}"
  if [[ "$_self" != "claude-account" && "$_self" == claude-* ]]; then
    _COMMAND=run
    _ACCOUNT="${_self#claude-}"
    _CLAUDE_ARGS=("$@")
    return
  fi

  # Normal dispatch
  case "${1:-}" in
    -h|--help)
      usage; exit 0 ;;
    -l|--list)
      _COMMAND=list ;;
    -i|--init)
      _COMMAND=init
      _ACCOUNT="${2:-}"
      [[ -n "$_ACCOUNT" ]] || fatal "--init requires an account name" ;;
    -s|--setup)
      _COMMAND=setup
      _ACCOUNT="${2:-}"
      [[ -n "$_ACCOUNT" ]] || fatal "--setup requires an account name" ;;
    "")
      usage; exit 1 ;;
    -*)
      fatal "Unknown option: $1" ;;
    *)
      _COMMAND=run
      _ACCOUNT="$1"
      shift
      _CLAUDE_ARGS=("$@") ;;
  esac
}


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_list() {
  if [[ ! -d "$_ACCOUNTS_DIR" ]]; then
    echo "No accounts directory found at $_ACCOUNTS_DIR" >&2
    return
  fi
  local _found=0
  for _dir in "$_ACCOUNTS_DIR"/*/; do
    [[ -d "$_dir" ]] || continue
    printf '%s\n' "${_dir%/}"
    _found=1
  done
  (( _found )) || echo "No accounts configured yet. Run: ${0##*/} --init <account>" >&2
}

setup_settings() {
  local _account_dir="$1"
  local _settings="$_account_dir/settings.json"
  local _status_cmd="${HOME}/.local/bin/claude-status"
  local _defaults
  _defaults=$(printf '{
  "editorMode": "vim",
  "theme": "auto",
  "statusLine": {"type": "command", "command": "%s"}
}' "$_status_cmd")

  if [[ -f "$_settings" ]]; then
    local _tmp
    _tmp=$(jq --argjson d "$_defaults" '. + $d' "$_settings") \
      || return
    printf '%s\n' "$_tmp" > "$_settings"
  else
    printf '%s\n' "$_defaults" > "$_settings"
  fi
}

cmd_setup() {
  local _account_dir="$_ACCOUNTS_DIR/$_ACCOUNT"
  [[ -d "$_account_dir" ]] \
    || fatal "Account '$_ACCOUNT' not found at $_account_dir. Run: ${0##*/} --init '$_ACCOUNT'"
  setup_settings "$_account_dir"
  echo "Settings updated: $_account_dir/settings.json" >&2
}

cmd_init() {
  local _account_dir="$_ACCOUNTS_DIR/$_ACCOUNT"
  if [[ -d "$_account_dir" ]]; then
    echo "Account '$_ACCOUNT' already exists at $_account_dir" >&2
  else
    mkdir -p "$_account_dir"
    echo "Created account directory: $_account_dir" >&2
  fi
  setup_settings "$_account_dir"
  print_status
  exec env CLAUDE_CONFIG_DIR="$_account_dir" "$_CLAUDE_BIN"
}

cmd_run() {
  local _account_dir="$_ACCOUNTS_DIR/$_ACCOUNT"
  [[ -d "$_account_dir" ]] \
    || fatal "Account '$_ACCOUNT' not found at $_account_dir. Run: ${0##*/} --init '$_ACCOUNT'"
  print_status
  exec env CLAUDE_CONFIG_DIR="$_account_dir" "$_CLAUDE_BIN" "${_CLAUDE_ARGS[@]}"
}


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
configure "$@"

case "$_COMMAND" in
  list)  cmd_list ;;
  init)  cmd_init ;;
  setup) cmd_setup ;;
  run)   cmd_run ;;
esac
