#! /usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

BRANCH=${1:?Usage: $0 <branch-name> [base-ref]}
DIRECTORY="@${BRANCH}"
BASE=${2:-origin/main}

# Create branch locally
git branch --no-track "$BRANCH" "$BASE" \
  || echo "WARNING - Branch '$BRANCH' already exists."

# Add worktree tracking the new remote branch
git worktree add "${DIRECTORY}" "${BRANCH}"

echo "Done. Worktree '$BRANCH' created in './$DIRECTORY/'."
