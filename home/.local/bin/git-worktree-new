#! /usr/bin/env bash

set -o errexit
set -o nounset
set -o pipefail

BRANCH=${1:?Usage: $0 <branch-name> [base-ref]}
BASE=${2:-main}

# Create remote branch from base
git push origin "origin/${BASE}:refs/heads/${BRANCH}" 2>/dev/null || \
  echo "Remote branch origin/${BRANCH} already exists, skipping push."

# Fetch so the remote ref is visible locally
git fetch origin "${BRANCH}"

# Add worktree tracking the new remote branch
git worktree add -b "${BRANCH}" "${BRANCH}" "origin/${BRANCH}"

# Set upstream explicitly (belt and suspenders)
git -C "${BRANCH}" branch --set-upstream-to="origin/${BRANCH}" "${BRANCH}"

echo "Done. Worktree '${BRANCH}' created, tracking origin/${BRANCH}."
